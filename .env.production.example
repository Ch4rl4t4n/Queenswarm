# Queenswarm production (Docker Compose) — copy to ``.env`` in the repo root.
# Strongly recommended: `./scripts/generate-env-secrets.sh >> .env` then reconcile LLM URLs.

# --- LLM (required by Settings — use mocks only in sandboxes via dummy keys LiteLLM short-circuits) ---
GROK_API_KEY=grok-live-or-placeholder
ANTHROPIC_API_KEY=sk-ant-live-or-placeholder
OPENAI_API_KEY=

# --- PostgreSQL (compose service: postgres) ---
POSTGRES_USER=queenswarm
POSTGRES_PASSWORD=changeme-strong
POSTGRES_DB=queenswarm
POSTGRES_URL=postgresql+asyncpg://queenswarm:changeme-strong@postgres:5432/queenswarm

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Neo4j ---
NEO4J_PASSWORD=openssl-rand-hex-16
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# --- Chroma (compose host ``chromadb``; internal port 8000) ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- Auth & security ---
SECRET_KEY=openssl-rand-hex-32-at-least-thirty-two-chars-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DOMAIN=queenswarm.love
CORS_ORIGINS=https://queenswarm.love,https://www.queenswarm.love,http://localhost:3000
RATE_LIMIT_ENABLED=true

# Bearer token minted via backend helper (same HS256 SECRET_KEY) for server-side proxies.
DASHBOARD_JWT=replace-with-signed-jwt

# Ballroom + dashboard WebSocket guest lanes (still pair with JWT for HTTP mutation routes).
BALLROOM_GUEST_WS=true
HIVE_DASHBOARD_GUEST_WS=true
NEXT_PUBLIC_HIVE_WS_GUEST=true
NEXT_PUBLIC_BALLROOM_GUEST_WS=true

# Grafana / monitoring
GRAFANA_ADMIN_PASSWORD=openssl-rand-hex-24
PROMETHEUS_PUBLISH_PORT=9090

# Recipe mutations (trusted operators only in prod)
RECIPE_CATALOG_MUTATIONS_ENABLED=false

# --- Readiness (leave false unless you need strict Neo4j/Chroma gating on /health/ready) ---
READINESS_REQUIRE_NEO4J=false
READINESS_REQUIRE_CHROMA=false

# --- Bee-hive relays ---
HIVE_WAGGLE_RELAY_ENABLED=true

# --- Celery / async workflows ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKFLOW_RUNS_ENABLED=true

# --- Frontend public ---
NEXT_PUBLIC_API_BASE=https://queenswarm.love/api/v1

# Published host ports (optional overrides)
# HTTP_PORT=80
# HTTPS_PORT=443
