# Queenswarm production (Docker Compose) — copy to ``.env`` in the repo root.
# Never commit real ``.env`` (see ``.gitignore``).

# --- LLM (required by Settings) ---
GROK_API_KEY=xai-production-key
ANTHROPIC_API_KEY=sk-ant-production-key
OPENAI_API_KEY=

# --- PostgreSQL (compose service: postgres) ---
POSTGRES_USER=queenswarm
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=queenswarm
POSTGRES_URL=postgresql+asyncpg://queenswarm:change-me-strong@postgres:5432/queenswarm

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Neo4j ---
NEO4J_PASSWORD=change-me-strong
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# --- Chroma (compose host ``chromadb``; internal port 8000) ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- Auth & security ---
SECRET_KEY=replace-with-openssl-rand-hex-32-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DOMAIN=queenswarm.love
CORS_ORIGINS=https://queenswarm.love,https://www.queenswarm.love,http://localhost:3000

# Rate limits (set false behind Nginx during initial bring-up)
RATE_LIMIT_ENABLED=false

# Recipe Library writes (pair with JWT allowlist in production)
RECIPE_CATALOG_MUTATIONS_ENABLED=true

# Readiness (leave false unless you need strict gates on /health/ready)
READINESS_REQUIRE_NEO4J=false
READINESS_REQUIRE_CHROMA=false

# Optional: disable Redis waggle loop in small deployments
HIVE_WAGGLE_RELAY_ENABLED=false

# Celery / async workflows (optional worker service)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKFLOW_RUNS_ENABLED=true

# Frontend (public URL the browser calls)
NEXT_PUBLIC_API_BASE=https://queenswarm.love/api/v1

# Published host ports (optional overrides for docker compose)
# HTTP_PORT=80
# HTTPS_PORT=443
# BACKEND_PUBLISH_PORT=8000
# FRONTEND_PUBLISH_PORT=3000
# CHROMA_PUBLISH_PORT=8001
