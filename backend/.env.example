# Local development — for production substitute docker Compose service names
# Example: postgres service host `postgres`, redis `redis`, chromadb `chromadb`.

# ===== LLM ROUTING (LiteLLM) =====
# Optional executor hint mirrors dashboard copy (primary chain still flows through WORKFLOW_BREAKER_*).
# LLM_MODEL=xai/grok-3-mini
GROK_API_KEY=xai-your-grok-key-here
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
OPENAI_API_KEY=sk-your-openai-key-optional

# ===== AUTO WORKFLOW BREAKER (LiteLLM) =====
WORKFLOW_BREAKER_PRIMARY_MODEL=xai/grok-3-mini
WORKFLOW_BREAKER_FALLBACK_MODEL=anthropic/claude-3-haiku-20240307
WORKFLOW_BREAKER_MAX_OUTPUT_TOKENS=4096
WORKFLOW_BREAKER_TEMPERATURE=0.15

# ===== DATABASES (localhost) =====
POSTGRES_URL=postgresql+asyncpg://queenswarm:devpass@localhost:5432/queenswarm
POSTGRES_USER=queenswarm
POSTGRES_PASSWORD=devpass
POSTGRES_DB=queenswarm

REDIS_URL=redis://localhost:6379/0
# Optional: separate broker/results for Celery (default: REDIS_URL).
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_strong_password

CHROMA_HOST=localhost
CHROMA_PORT=8000

# ===== BEE-HIVE TUNING =====
SUB_SWARM_SIZE=8
HIVE_SYNC_INTERVAL_SEC=300
REWARD_THRESHOLD_PASS=0.7
# Pollen per bee after a fully verified swarm LangGraph run (0 disables):
# VERIFIED_SWARM_POLLEN_PER_BEE=1.0
RAPID_LOOP_TIMEOUT_SEC=60
IMITATION_TOP_K=3
MEMORY_DECAY_DAYS=14
SCOUT_SWARM_SIZE=8
EVAL_SWARM_SIZE=6
SIM_SWARM_SIZE=5
ACTION_SWARM_SIZE=10
HIVE_WAGGLE_RELAY_ENABLED=true
# Outcome gate: simulator must emit verification_passed + confidence ≥ REWARD_THRESHOLD_PASS.
# EXPOSE_RAW_STEP_OUTPUTS=false
# Simulator GenericBee emits synthetic verification (testing only — keep false in prod).
# SIMULATOR_STUB_AUTO_VERIFY=false
# Disable POST …/run? defer_to_worker if you omit workers:
# CELERY_WORKFLOW_RUNS_ENABLED=true
# Persist simulations rows after each swarm LangGraph cycle (synthetic until Docker binds):
# SIMULATION_AUDIT_ROWS_ENABLED=true
# SIMULATION_DOCKER_EXECUTION_ENABLED=false
# Ephemeral probe after each cycle when Docker mode is on (requires docker CLI on host):
# SIMULATION_DOCKER_IMAGE=busybox:1.36
# SIMULATION_DOCKER_TIMEOUT_SEC=30
# SIMULATION_DOCKER_LOG_TRUNCATE_CHARS=8192
# Recipe semantic search (GET /api/v1/recipes/search):
# RECIPE_CHROMA_SEARCH_LIMIT_CAP=20
# RECIPE_CHROMA_MIN_SIMILARITY=0.0
# Breaker Chrom hint cosine cutoff (Recipe Library retrieval):
# RECIPE_LIBRARY_MATCH_THRESHOLD=0.85
# After verified swarm cycles, upsert matching_recipe into Chroma (needs reachable Chroma):
# RECIPE_CHROMA_AUTO_SYNC_ON_VERIFY=false
# POST/PATCH /api/v1/recipes mirror Chroma embeddings (disable if cluster unavailable):
# RECIPE_WRITE_SYNC_CHROMA=true
# Recipe catalog POST/PATCH default off in production — enable with trusted principals only:
# RECIPE_CATALOG_MUTATIONS_ENABLED=false
# Optional JWT sub allowlist (CSV); when set, only these subjects may POST/PATCH/DELETE recipes:
# RECIPE_CATALOG_MUTATION_ALLOWLIST=hive-ci,recipe-keeper
# Optional OAuth scope string that must appear in the JWT ``scope`` claim (from POST /auth/token):
# RECIPE_CATALOG_MUTATION_REQUIRED_SCOPE=recipes:write
# Max JSON-encoded workflow_template size (bytes):
# RECIPE_WORKFLOW_TEMPLATE_MAX_JSON_BYTES=262144

# ===== SECURITY =====
SECRET_KEY=dev-secret-change-me-to-at-least-thirty-two-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Optional M2M mint: POST /api/v1/auth/token (HTTP Basic; secret ≥32 chars). Set both or neither.
# HIVE_TOKEN_CLIENT_ID=hive-ci
# HIVE_TOKEN_CLIENT_SECRET=change-me-to-at-least-thirty-two-characters!!
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BURST_MAX=10
RATE_LIMIT_BURST_WINDOW_SEC=1.0
RATE_LIMIT_SUSTAIN_MAX=100
RATE_LIMIT_SUSTAIN_WINDOW_SEC=60.0
HEALTH_READINESS_CACHE_SEC=3.0
# When true, /health/ready returns 503 if Neo4j or Chroma checks fail:
# READINESS_REQUIRE_NEO4J=false
# READINESS_REQUIRE_CHROMA=false

# ===== DOMAIN & CORS =====
DOMAIN=queenswarm.love
CORS_ORIGINS=https://queenswarm.love,https://www.queenswarm.love,http://localhost:3000

# ===== EMAIL (agents → deliver_to_email) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=operator@your-domain.com
# Optional Slack webhook legacy (majority of operators use SMTP only).
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
NOTION_API_KEY=secret_your_notion_integration_key

# ===== SCRAPING =====
YOUTUBE_API_KEY=your-youtube-data-api-v3-key
USER_AGENT=QueenswarmBot/2.0
PROXY_LIST_URL=

# ===== COST GOVERNOR =====
DAILY_BUDGET_USD=10.00
WEEKLY_BUDGET_USD=50.00
MONTHLY_BUDGET_USD=200.00
COST_WARNING_THRESHOLD=0.8
