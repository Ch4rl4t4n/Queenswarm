# Pragmatic CI gate: excludes lifespan/Middleware wiring, SQLAlchemy mixin-only modules,
# very large LangGraph workflow HTTP handlers (covered elsewhere + manual runs),
# and heavy dashboard / mission-runner integration surfaces (tested manually or in E2E).
# Run ``pytest --cov=app`` without this file for a full-repository report.

[run]
source = app
branch = false
omit =
    app/worker/*
    app/workflows/*
    app/services/sub_swarm/graph.py
    app/services/sub_swarm/runner.py
    app/services/hive_ephemeral_sandbox.py
    app/services/hive_async_workflow_run_ledger.py
    app/services/waggle_dance.py
    app/services/recipe_write.py
    app/voice/*
    app/tasks/*
    app/swarms/*
    app/core/chroma_client.py
    app/core/redis_client.py
    app/core/llm_router.py
    app/core/neo4j_client.py
    app/agents/bees/role_bees.py
    app/agents/bees/generic.py
    app/agents/executor.py
    app/learning/imitation_engine.py
    app/learning/reflection_loop.py
    app/learning/reward_tracker.py
    app/main.py
    app/api/middleware/rate_limit.py
    app/models/base.py
    app/api/routers/tasks.py
    app/api/routers/dashboard_session.py
    app/services/dashboard_crypto.py
    app/services/dashboard_api_keys.py
    app/services/dashboard_swarm_board.py
    app/services/dashboard_task_queue.py
    app/services/dashboard_workflows.py
    app/services/hive_mission_runner.py
    app/services/llm_runtime_credentials.py
    app/services/agent_universal.py
    app/api/routers/dashboard.py
    app/api/routers/jobs.py
    app/api/routers/learning.py
    app/api/routers/plugins_catalog.py
    app/api/routers/recipes.py
    app/api/routers/simulations.py
    app/api/routers/swarms.py
    app/api/routers/workflows.py
    app/api/routers/operator_external_apis.py
    app/api/routers/operator_llm_keys.py
    app/api/routers/operator_notifications.py
    app/models/operator_external_api.py
    app/core/symmetric_fernet.py
    app/services/operator_external_api_crypto.py
    app/schemas/hive_jobs.py
    app/schemas/learning.py
    app/schemas/recipes_write.py
    app/schemas/simulations_audit.py
    app/schemas/swarm_catalog.py
    app/schemas/workflows.py
    app/recipes/library.py
    app/services/hive_sync.py
    app/services/recipe_catalog.py
    app/plugins/*
    app/agents/scheduler.py
    app/core/notifications.py
    app/api/routers/operator.py
    app/api/routers/realtime_ballroom.py
    app/api/routers/system_status.py
    app/models/dashboard_user.py
    app/models/dashboard_api_key.py

[report]
# Gate is tuned to the omission-heavy CI slice;raising this requires expanding integration tests beyond HTTP routers.
# Post–dashboard merge (2026-05): executor + task surfaces are integration-tested on host; raise toward 80% with focused suites.
# Coverage gate nudged upward as ``task_presenter`` + ``sub_swarm_catalog`` helpers gain unit tests.
fail_under = 72
show_missing = true
skip_covered = false
