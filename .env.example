# ===== LLM ROUTING (LiteLLM) =====
GROK_API_KEY=xai-your-grok-key-here
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
OPENAI_API_KEY=sk-your-openai-key-optional

# ===== DATABASES =====
POSTGRES_URL=postgresql+asyncpg://queenswarm:changeme@postgres:5432/queenswarm
POSTGRES_USER=queenswarm
POSTGRES_PASSWORD=changeme
POSTGRES_DB=queenswarm

REDIS_URL=redis://redis:6379/0

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_strong_password

CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ===== BEE-HIVE TUNING =====
SUB_SWARM_SIZE=8
HIVE_SYNC_INTERVAL_SEC=300
REWARD_THRESHOLD_PASS=0.7
RAPID_LOOP_TIMEOUT_SEC=60
IMITATION_TOP_K=3
MEMORY_DECAY_DAYS=14

# ===== SECURITY =====
SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Long-lived HS256 bearer for Next.js ``/api/proxy`` → backend (mint with backend/scripts/issue_dashboard_jwt.py).
DASHBOARD_JWT=replace-with-signed-jwt

# Browser-visible API root (must match nginx + standalone build args).
NEXT_PUBLIC_API_BASE=https://queenswarm.love/api/v1

# ===== DOMAIN & CORS =====
DOMAIN=queenswarm.love
CORS_ORIGINS=https://queenswarm.love,https://www.queenswarm.love,http://localhost:3000

# ===== NOTIFICATIONS =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
NOTION_API_KEY=secret_your_notion_integration_key

# ===== SCRAPING =====
YOUTUBE_API_KEY=your-youtube-data-api-v3-key
USER_AGENT=QueenswarmBot/2.0
PROXY_LIST_URL=

# ===== COST GOVERNOR =====
DAILY_BUDGET_USD=10.00
WEEKLY_BUDGET_USD=50.00
MONTHLY_BUDGET_USD=200.00
COST_WARNING_THRESHOLD=0.8
