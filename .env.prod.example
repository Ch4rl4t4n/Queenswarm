# =============================================================================
# Queenswarm PRODUCTION — copy to ``.env.prod`` (gitignored). Host: queenswarm.love
# =============================================================================
# Tuned for a **~32 GB RAM** single host alongside ``docker-compose.prod.yml`` caps
# (see overlay: postgres/redis/neo4j/backend/celery). For ~16 GB, reduce mem_limit locally.
# Never commit this file with real secrets; rotate quarterly per security policy.

DOMAIN=queenswarm.love
# Optional: override nginx default vhost file (default is production ``conf.d/queenswarm.love.conf``).
# QS_NGINX_SITE_CONF=./deploy/nginx/conf.d/queenswarm.love.conf

# ----- TLS (host; paths referenced in deploy/nginx/queenswarm.love.conf) -----
#   /etc/letsencrypt/live/queenswarm.love/{fullchain.pem,privkey.pem}
# Include ``www.queenswarm.love`` in the same cert if you serve both hostnames.

NEXT_PUBLIC_API_BASE=https://queenswarm.love/api/v1
CORS_ORIGINS=https://queenswarm.love,https://www.queenswarm.love
OAUTH_FRONTEND_PUBLIC_ORIGIN=https://queenswarm.love

# Production OAuth apps (redirect ``https://queenswarm.love/api/auth/callback/oauth``)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_NOTION_CLIENT_ID=
OAUTH_NOTION_CLIENT_SECRET=
OAUTH_STRIPE_CLIENT_ID=
OAUTH_STRIPE_CLIENT_SECRET=

SECRET_KEY=openssl-rand-hex-32-production
DASHBOARD_JWT=mint-with-backend-scripts-issue_dashboard_jwt-py-production

POSTGRES_USER=queenswarm
POSTGRES_PASSWORD=production-postgres-password
POSTGRES_DB=queenswarm
POSTGRES_URL=postgresql+asyncpg://queenswarm:production-postgres-password@postgres:5432/queenswarm

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=production-neo4j-password

VECTOR_STORE_BACKEND=qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# Legacy rollback only:
# VECTOR_STORE_BACKEND=chroma
# CHROMA_HOST=chromadb
# CHROMA_PORT=8000

GROK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

GRAFANA_PASSWORD=production-grafana-admin
GF_SERVER_ROOT_URL=https://queenswarm.love/grafana/

NEXT_PUBLIC_QS_POLL_PROFILE=low_ram

# PRODUCTION_HEALTH_URL=https://queenswarm.love/health

# ----- Phase 5.2 — post-deploy probes (optional) -----
# OPERATOR_SMOKE_JWT=   # export after minting JWT; used by scripts/health-check.sh
# POST_DEPLOY_HEALTH=1 ./scripts/deploy-prod.sh

# ----- JWT & rate limits -----
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# RATE_LIMIT_ENABLED=true

# ----- Readiness strict deps -----
# READINESS_REQUIRE_NEO4J=false
# READINESS_REQUIRE_CHROMA=false

# ----- Hive Mind + vectors -----
# HIVE_MIND_ENABLED=true
# HIVE_MIND_CHROMA_ENABLED=true
# VECTOR_STORE_BACKEND=qdrant
# QDRANT_HTTPS=false

# ----- Ballroom / dashboard WebSocket -----
# BALLROOM_GUEST_WS=true
# HIVE_DASHBOARD_GUEST_WS=true
