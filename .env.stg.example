# =============================================================================
# Queenswarm STAGING — copy to ``.env.stg`` (gitignored). Host: stg.queenswarm.love
# =============================================================================
# Use **separate** DB passwords, OAuth apps, JWT secrets, and Grafana admin password
# from production. Nginx Basic Auth is independent (see STAGING_* below).

# ----- Staging edge (nginx — consumed by scripts/deploy-stg.sh) -----
# REQUIRED for compose: select the staging vhost (not production queenswarm.love.conf).
QS_NGINX_SITE_CONF=./deploy/nginx/stg.queenswarm.love.conf
STAGING_BASIC_AUTH_USER=stg-operator
STAGING_BASIC_AUTH_PASSWORD=replace-with-long-random-passphrase
# Optional: comma-separated IPs or CIDRs that may bypass Basic Auth (office / bastion).
# Leave empty to require password for all clients (except ``location = /health`` on stg vhost).
STAGING_IP_ALLOWLIST=

# ----- TLS (host paths mounted read-only into nginx; never commit keys) -----
# The staging vhost expects:
#   /etc/letsencrypt/live/stg.queenswarm.love/fullchain.pem
#   /etc/letsencrypt/live/stg.queenswarm.love/privkey.pem
# Issue a cert whose SAN includes ``stg.queenswarm.love`` (do not reuse prod-only SAN).
# Example (adjust webroot / DNS challenge to your host):
#   certbot certonly --webroot -w /var/www/certbot -d stg.queenswarm.love

# ----- Public URLs (must match TLS cert + Next build args) -----
DOMAIN=stg.queenswarm.love
NEXT_PUBLIC_API_BASE=https://stg.queenswarm.love/api/v1
CORS_ORIGINS=https://stg.queenswarm.love,http://localhost:3000
OAUTH_FRONTEND_PUBLIC_ORIGIN=https://stg.queenswarm.love

# ----- Hosted OAuth — register **staging** redirect URI with each vendor -----
# Redirect path is ``/api/auth/callback/oauth`` on the **staging** origin above.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_NOTION_CLIENT_ID=
OAUTH_NOTION_CLIENT_SECRET=
OAUTH_STRIPE_CLIENT_ID=
OAUTH_STRIPE_CLIENT_SECRET=

# ----- Core secrets (staging-only values; never reuse production literals) -----
SECRET_KEY=openssl-rand-hex-32-staging
DASHBOARD_JWT=mint-with-backend-scripts-issue_dashboard_jwt-py-staging

# ----- Databases (isolated per compose project ``queenswarm_stg`` volumes) -----
POSTGRES_USER=queenswarm
POSTGRES_PASSWORD=staging-postgres-password
POSTGRES_DB=queenswarm_stg
POSTGRES_URL=postgresql+asyncpg://queenswarm:staging-postgres-password@postgres:5432/queenswarm_stg

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=staging-neo4j-password

# Vectors: baseline Compose has no Qdrant — use pgvector (``qdrant`` in env is coerced to pgvector at startup).
VECTOR_STORE_BACKEND=pgvector
# Legacy rollback only:
# VECTOR_STORE_BACKEND=chroma
# CHROMA_HOST=chromadb
# CHROMA_PORT=8000

# ----- LLM (optional staging keys — can share or use cheap tier) -----
GROK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ----- Grafana (staging admin) -----
GRAFANA_PASSWORD=staging-grafana-admin
GF_SERVER_ROOT_URL=https://stg.queenswarm.love/grafana/

# ----- Poll profile (laptop-friendly) -----
NEXT_PUBLIC_QS_POLL_PROFILE=low_ram

# ----- Health script helpers (optional overrides) -----
# STAGING_HEALTH_URL=https://stg.queenswarm.love/health

# ----- Phase 5.2 — smoke / monitoring probes (optional; never commit real JWTs) -----
# Mint operator JWT on the backend container, then export for scripts/health-check.sh + smoke-edge:
#   docker compose -p queenswarm_stg exec backend python scripts/issue_dashboard_jwt.py
# OPERATOR_SMOKE_JWT=
# POST_DEPLOY_SMOKE=1 ./scripts/deploy-stg.sh
# POST_DEPLOY_HEALTH=1 ./scripts/deploy-stg.sh

# ----- JWT & rate limits (see backend/.env.example for full list) -----
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# RATE_LIMIT_ENABLED=true

# ----- Readiness strict deps (optional; 503 on /health/ready when enabled and store down) -----
# READINESS_REQUIRE_NEO4J=false
# READINESS_REQUIRE_CHROMA=false  # name kept for compat; gates vector tier ping when true

# ----- Hive Mind + vectors -----
# HIVE_MIND_ENABLED=true
# HIVE_MIND_CHROMA_ENABLED=true

# ----- Ballroom / dashboard WebSocket guest lanes -----
# BALLROOM_GUEST_WS=true
# HIVE_DASHBOARD_GUEST_WS=true

# ----- Connectors / External projects (operator tuning) -----
# RECIPE_WRITE_SYNC_CHROMA=true
# PHASE3_OBSIDIAN_WATCH_ENABLED=false
